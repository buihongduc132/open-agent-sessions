{
  "name": "open-agent-sessions",
  "version": "0.1.0",
  "description": "Unified session management library for AI coding agents (OpenCode, Codex, Claude)",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "oas": "./bin/oas"
  },
  "scripts": {
    "test": "bun test",
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "sessions",
    "opencode",
    "codex",
    "claude",
    "session-management",
    "ai-tools"
  ],
  "author": "open-agent-sessions contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhd/open-agent-sessions.git"
  },
  "bugs": {
    "url": "https://github.com/bhd/open-agent-sessions/issues"
  },
  "homepage": "https://github.com/bhd/open-agent-sessions#readme",
  "engines": {
    "bun": ">=1.0.0"
  },
  "dependencies": {
    "@opentui/core": "^0.1.74",
    "@opentui/react": "^0.1.74",
    "react": "^19.2.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.8",
    "typescript": "^5.4.5"
  }
}
