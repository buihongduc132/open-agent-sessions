#!/usr/bin/env bun
import { homedir } from "node:os";
import { join, resolve } from "node:path";
import { Database } from "bun:sqlite";

const DB_PATH = join(homedir(), ".local", "share", "opencode", "opencode.db");

function findProjectId(db: Database, cwd: string): string | null {
  const normalized = resolve(cwd);
  const result = db
    .query<{ id: string }, [string]>(
      "SELECT id FROM project WHERE worktree = ?"
    )
    .get(normalized);
  return result?.id ?? null;
}

function listRecentSessions(limit: number = 10) {
  const cwd = process.cwd();
  const db = new Database(DB_PATH, { readonly: true });
  
  const projectId = findProjectId(db, cwd);
  if (!projectId) {
    console.error(`No OpenCode project found for: ${cwd}`);
    process.exit(1);
  }

  const sessions = db
    .query<
      { id: string; title: string; time_updated: number; message_count: number },
      [string, number]
    >(
      `SELECT 
        s.id,
        s.title,
        s.time_updated,
        (SELECT COUNT(*) FROM message WHERE session_id = s.id) as message_count
      FROM session s
      WHERE s.project_id = ?
      ORDER BY s.time_updated DESC
      LIMIT ?`
    )
    .all(projectId, limit);

  if (sessions.length === 0) {
    console.log("No sessions found.");
    return;
  }

  console.log("Recent sessions:");
  console.log("");
  
  for (const session of sessions) {
    const date = new Date(session.time_updated);
    const title = session.title || "(untitled)";
    console.log(`${session.id}  ${title}`);
    console.log(`${' '.repeat(session.id.length)}  ${date.toLocaleString()}  (${session.message_count} messages)`);
    console.log("");
  }
  
  db.close();
}

function findSession(sessionId: string) {
  const db = new Database(DB_PATH, { readonly: true });
  
  const session = db
    .query<
      { id: string; title: string; directory: string; time_created: number; time_updated: number; message_count: number },
      [string]
    >(
      `SELECT 
        s.id,
        s.title,
        s.directory,
        s.time_created,
        s.time_updated,
        (SELECT COUNT(*) FROM message WHERE session_id = s.id) as message_count
      FROM session s
      WHERE s.id LIKE ?`
    )
    .get(`${sessionId}%`);

  if (!session) {
    console.error(`Session not found: ${sessionId}`);
    process.exit(1);
  }

  const created = new Date(session.time_created);
  const updated = new Date(session.time_updated);
  
  console.log(`Session: ${session.id}`);
  console.log(`Title:   ${session.title || "(untitled)"}`);
  console.log(`Dir:     ${session.directory}`);
  console.log(`Created: ${created.toLocaleString()}`);
  console.log(`Updated: ${updated.toLocaleString()}`);
  console.log(`Messages: ${session.message_count}`);
  
  db.close();
}

function showHelp() {
  console.log("Open Agent Sessions (oas) - Session management CLI");
  console.log("");
  console.log("Usage:");
  console.log("  oas list [limit]       List recent sessions (default: 10)");
  console.log("  oas recent [limit]     Same as list");
  console.log("  oas find <session-id>  Show session details");
  console.log("  oas show <session-id>  Same as find");
  console.log("  oas --help             Show this help message");
  console.log("");
  console.log("Examples:");
  console.log("  oas list               List last 10 sessions");
  console.log("  oas list 20            List last 20 sessions");
  console.log("  oas find abc123        Show details for session abc123");
  process.exit(0);
}

const command = process.argv[2];
const arg = process.argv[3];

if (!command || command === "--help" || command === "-h") {
  showHelp();
}

if (command === "list" || command === "recent") {
  if (arg === "--help" || arg === "-h") {
    showHelp();
  }
  const limit = arg ? parseInt(arg, 10) : 10;
  if (isNaN(limit) || limit <= 0) {
    console.error("Error: limit must be a positive number");
    process.exit(1);
  }
  listRecentSessions(limit);
} else if (command === "find" || command === "show") {
  if (!arg || arg === "--help" || arg === "-h") {
    console.error("Usage: oas find <session-id>");
    process.exit(1);
  }
  findSession(arg);
} else {
  console.log("Usage: oas list [limit]");
  console.log("       oas recent [limit]");
  console.log("       oas find <session-id>");
  console.log("       oas show <session-id>");
  process.exit(1);
}
