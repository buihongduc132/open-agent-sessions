#!/usr/bin/env bun
import { homedir } from "node:os";
import { join, resolve } from "node:path";
import { existsSync } from "node:fs";
import { Database } from "bun:sqlite";

// CLI command imports
import { runSessionsCommand, type SessionsService } from "../src/cli/sessions";
import { runReadCommand, type ReadService } from "../src/cli/read";
import { runSearchCommand, type SearchService } from "../src/cli/search";
import { runListCommand, type ListService } from "../src/cli/list";
import { runDetailCommand, type DetailService } from "../src/cli/detail";
import { runCloneCommand } from "../src/cli/clone";

// Core imports
import { createAdapterRegistry } from "../src/core/registry";
import { createListService } from "../src/core/list";
import { createCloneService, type CloneRegistry } from "../src/core/clone";
import type { SessionSummary, SessionDetail, TimeRangeOptions, SessionReadOptions, SearchQuery, SessionListQuery, SessionListResult } from "../src/core/types";

// Config imports
import { loadConfigFromFile, type Config } from "../src/config";

// Adapter imports
import { createOpenCodeAdapter, createOpenCodeCloneDestinationAdapter, createCodexCloneSourceAdapter } from "../src/adapters";

const DB_PATH = join(homedir(), ".local", "share", "opencode", "opencode.db");

// ============================================================================
// Legacy Functions (for backward compatibility)
// ============================================================================

function findProjectId(db: Database, cwd: string): string | null {
  const normalized = resolve(cwd);
  const result = db
    .query<{ id: string }, [string]>(
      "SELECT id FROM project WHERE worktree = ?"
    )
    .get(normalized);
  return result?.id ?? null;
}

function listRecentSessions(limit: number = 10) {
  const cwd = process.cwd();
  let db: Database | null = null;

  try {
    db = new Database(DB_PATH, { readonly: true });

    const projectId = findProjectId(db, cwd);
    if (!projectId) {
      console.error(`No OpenCode project found for: ${cwd}`);
      process.exit(1);
    }

    const sessions = db
      .query<
        { id: string; title: string; time_updated: number; message_count: number },
        [string, number]
      >(
        `SELECT
          s.id,
          s.title,
          s.time_updated,
          (SELECT COUNT(*) FROM message WHERE session_id = s.id) as message_count
        FROM session s
        WHERE s.project_id = ?
        ORDER BY s.time_updated DESC
        LIMIT ?`
      )
      .all(projectId, limit);

    if (sessions.length === 0) {
      console.log("No sessions found.");
      return;
    }

    console.log("Recent sessions:");
    console.log("");

    for (const session of sessions) {
      const date = new Date(session.time_updated);
      const title = session.title || "(untitled)";
      console.log(`${session.id}  ${title}`);
      console.log(`${' '.repeat(session.id.length)}  ${date.toLocaleString()}  (${session.message_count} messages)`);
      console.log("");
    }
  } finally {
    if (db) {
      db.close();
    }
  }
}

function findSession(sessionId: string) {
  let db: Database | null = null;

  try {
    db = new Database(DB_PATH, { readonly: true });

    const session = db
      .query<
        { id: string; title: string; directory: string; time_created: number; time_updated: number; message_count: number },
        [string]
      >(
        `SELECT
          s.id,
          s.title,
          s.directory,
          s.time_created,
          s.time_updated,
          (SELECT COUNT(*) FROM message WHERE session_id = s.id) as message_count
        FROM session s
        WHERE s.id LIKE ?`
      )
      .get(`${sessionId}%`);

    if (!session) {
      console.error(`Session not found: ${sessionId}`);
      process.exit(1);
    }

    const created = new Date(session.time_created);
    const updated = new Date(session.time_updated);

    console.log(`Session: ${session.id}`);
    console.log(`Title:   ${session.title || "(untitled)"}`);
    console.log(`Dir:     ${session.directory}`);
    console.log(`Created: ${created.toLocaleString()}`);
    console.log(`Updated: ${updated.toLocaleString()}`);
    console.log(`Messages: ${session.message_count}`);
  } finally {
    if (db) {
      db.close();
    }
  }
}

// ============================================================================
// Config Loading
// ============================================================================

function getDefaultConfig(): Config {
  return {
    agents: [
      {
        agent: "opencode",
        alias: "default",
        enabled: true,
        storage: { mode: "auto" },
      },
    ],
  };
}

function loadConfig(): Config {
  // Try to load from default config path
  const configPaths = [
    join(process.cwd(), "oas.config.yaml"),
    join(process.cwd(), "oas.config.yml"),
    join(homedir(), ".config", "oas", "config.yaml"),
    join(homedir(), ".config", "oas", "config.yml"),
  ];

  for (const path of configPaths) {
    if (existsSync(path)) {
      try {
        return loadConfigFromFile(path);
      } catch (error) {
        console.error(`Failed to load config from ${path}: ${error instanceof Error ? error.message : String(error)}`);
        process.exit(1);
      }
    }
  }

  // Return default config if no config file found
  return getDefaultConfig();
}

// ============================================================================
// Service Creation
// ============================================================================

function createSessionsService(config: Config): SessionsService {
  const registry = createAdapterRegistry(config, {
    opencode: (entry) => createOpenCodeAdapter(entry, { cwd: process.cwd() }),
  });

  return async (query: { cwd: string; timeRange: TimeRangeOptions }) => {
    const results: SessionSummary[] = [];
    const errors: { agent: "opencode" | "codex" | "claude"; alias: string; message: string }[] = [];

    for (const adapter of registry.adapters) {
      try {
        if (adapter.listSessionsByTimeRange) {
          const sessions = await adapter.listSessionsByTimeRange(query.timeRange);
          results.push(...sessions);
        } else {
          // Fallback to listSessions if time range not supported
          const sessions = await adapter.listSessions();
          // Apply time filtering manually
          const filtered = sessions.filter((s) => {
            const updated = Date.parse(s.updated_at);
            if (query.timeRange.since !== undefined && updated < query.timeRange.since) {
              return false;
            }
            if (query.timeRange.until !== undefined && updated > query.timeRange.until) {
              return false;
            }
            return true;
          });
          results.push(...filtered);
        }
      } catch (error) {
        errors.push({
          agent: adapter.agent,
          alias: adapter.alias,
          message: error instanceof Error ? error.message : String(error),
        });
      }
    }

    // Sort by updated_at descending
    results.sort((a, b) => Date.parse(b.updated_at) - Date.parse(a.updated_at));

    // Apply limit
    const limit = query.timeRange.limit ?? 50;
    const limited = limit > 0 ? results.slice(0, limit) : results;

    return { sessions: limited, errors };
  };
}

function createReadService(config: Config): ReadService {
  const registry = createAdapterRegistry(config, {
    opencode: (entry) => createOpenCodeAdapter(entry, { cwd: process.cwd() }),
  });

  return async (query: { agent: string; alias: string; id: string }, options: SessionReadOptions) => {
    const adapter = registry.adapters.find(
      (a) => a.agent === query.agent && a.alias === query.alias
    );

    if (!adapter) {
      return null;
    }

    // Access the underlying adapter's getSessionDetail method
    // We need to get the adapter from the registry entry
    const entry = config.agents.find(
      (e) => e.agent === query.agent && e.alias === query.alias
    );

    if (!entry) {
      return null;
    }

    // Create a fresh adapter for this query to access getSessionDetail
    const freshAdapter = createOpenCodeAdapter(entry as any, { cwd: process.cwd() });
    
    if (!freshAdapter.getSessionDetail) {
      throw new Error(`Adapter does not support session detail retrieval`);
    }

    return freshAdapter.getSessionDetail(query.id, options);
  };
}

function createSearchService(config: Config): SearchService {
  return async (query: SearchQuery) => {
    const results: SessionSummary[] = [];
    const errors: { agent: "opencode" | "codex" | "claude"; alias: string; message: string }[] = [];

    for (const entry of config.agents.filter((e) => e.enabled)) {
      try {
        const adapter = createOpenCodeAdapter(entry as any, { cwd: query.cwd ?? process.cwd() });
        
        if (adapter.searchSessions) {
          const sessions = await adapter.searchSessions(query);
          results.push(...sessions);
        }
      } catch (error) {
        errors.push({
          agent: entry.agent,
          alias: entry.alias,
          message: error instanceof Error ? error.message : String(error),
        });
      }
    }

    // Sort by updated_at descending
    results.sort((a, b) => Date.parse(b.updated_at) - Date.parse(a.updated_at));

    return { sessions: results, errors };
  };
}

function createListServiceFromConfig(config: Config): ListService {
  const registry = createAdapterRegistry(config, {
    opencode: (entry) => createOpenCodeAdapter(entry, { cwd: process.cwd() }),
  });

  return createListService(registry);
}

function createDetailService(config: Config): DetailService {
  return async (query) => {
    const entry = config.agents.find(
      (e) => e.agent === query.agent && e.alias === query.alias && e.enabled
    );

    if (!entry) {
      return null;
    }

    const adapter = createOpenCodeAdapter(entry as any, { cwd: process.cwd() });
    
    if (!adapter.getSessionDetail) {
      throw new Error(`Adapter does not support session detail retrieval`);
    }

    return adapter.getSessionDetail(query.id, {});
  };
}

function createCloneServiceFromConfig(config: Config) {
  const cwd = process.cwd();
  
  const registry: CloneRegistry = {
    getSource: (source) => {
      if (source.agent !== "codex" || !source.alias) {
        return undefined;
      }
      
      const entry = config.agents.find(
        (e) => e.agent === "codex" && e.alias === source.alias && e.enabled
      );
      
      if (!entry) {
        return undefined;
      }
      
      return createCodexCloneSourceAdapter(entry as any, { cwd });
    },
    
    getDestination: (destination) => {
      if (destination.agent !== "opencode") {
        return undefined;
      }
      
      const entry = config.agents.find(
        (e) => e.agent === "opencode" && e.alias === destination.alias && e.enabled
      );
      
      if (!entry) {
        return undefined;
      }
      
      return createOpenCodeCloneDestinationAdapter(entry as any, { cwd });
    },
    
    listSources: (agent) => {
      if (agent !== "codex") return [];
      return config.agents
        .filter((e) => e.agent === "codex" && e.enabled)
        .map((e) => e.alias);
    },
    
    listDestinations: (agent) => {
      if (agent !== "opencode") return [];
      return config.agents
        .filter((e) => e.agent === "opencode" && e.enabled)
        .map((e) => e.alias);
    },
  };
  
  return createCloneService(registry);
}

// ============================================================================
// Argument Parsing
// ============================================================================

interface ParsedArgs {
  command: string;
  options: Record<string, string | number | boolean>;
  positional: string[];
}

function parseArgs(argv: string[]): ParsedArgs {
  const result: ParsedArgs = {
    command: "",
    options: {},
    positional: [],
  };

  let i = 0;
  while (i < argv.length) {
    const arg = argv[i];

    if (arg.startsWith("--")) {
      const key = arg.slice(2);
      
      // Handle --flag (boolean)
      if (i + 1 >= argv.length || argv[i + 1].startsWith("-")) {
        result.options[key] = true;
        i++;
        continue;
      }

      // Handle --key value
      const value = argv[i + 1];
      if (value !== undefined) {
        // Try to parse as number
        const num = Number(value);
        result.options[key] = isNaN(num) ? value : num;
        i += 2;
        continue;
      }
      i++;
    } else if (arg.startsWith("-") && arg !== "-") {
      // Short flags
      const key = arg.slice(1);
      result.options[key] = true;
      i++;
    } else {
      // Positional argument
      if (!result.command) {
        result.command = arg;
      } else {
        result.positional.push(arg);
      }
      i++;
    }
  }

  return result;
}

// ============================================================================
// Command Handlers
// ============================================================================

async function handleSessionsCommand(parsed: ParsedArgs): Promise<void> {
  // Validate --limit is a number when provided
  if (parsed.options["limit"] !== undefined) {
    const limit = parsed.options["limit"];
    if (typeof limit !== "number" || isNaN(limit)) {
      console.error("Invalid --limit value: must be a number");
      process.exit(1);
    }
  }

  // Validate --format is either "text" or "json" when provided
  if (parsed.options["format"] !== undefined) {
    const format = parsed.options["format"];
    if (format !== "text" && format !== "json") {
      console.error("Invalid --format value: must be 'text' or 'json'");
      process.exit(1);
    }
  }

  const config = loadConfig();
  const getSessions = createSessionsService(config);

  const result = await runSessionsCommand({
    last: parsed.options["last"] as string | undefined,
    since: parsed.options["since"] as string | undefined,
    until: parsed.options["until"] as string | undefined,
    limit: parsed.options["limit"] as number | undefined,
    format: parsed.options["format"] as "text" | "json" | undefined,
    config,
    getSessions,
  });

  process.stdout.write(result.stdout);
  process.stderr.write(result.stderr);
  process.exit(result.exitCode);
}

async function handleReadCommand(parsed: ParsedArgs): Promise<void> {
  // Validate --first is a number when provided
  if (parsed.options["first"] !== undefined) {
    const first = parsed.options["first"];
    if (typeof first !== "number" || isNaN(first)) {
      console.error("Invalid --first value: must be a number");
      process.exit(1);
    }
  }

  // Validate --last is a number when provided
  if (parsed.options["last"] !== undefined) {
    const last = parsed.options["last"];
    if (typeof last !== "number" || isNaN(last)) {
      console.error("Invalid --last value: must be a number");
      process.exit(1);
    }
  }

  // Validate --format is either "text" or "json" when provided
  if (parsed.options["format"] !== undefined) {
    const format = parsed.options["format"];
    if (format !== "text" && format !== "json") {
      console.error("Invalid --format value: must be 'text' or 'json'");
      process.exit(1);
    }
  }

  const config = loadConfig();
  const getSession = createReadService(config);

  // Support positional session-id: `oas read <session-id>`
  const sessionSpec = parsed.options["session"] as string | undefined || parsed.positional[0];

  const result = await runReadCommand({
    session: sessionSpec,
    agent: parsed.options["agent"] as string | undefined,
    alias: parsed.options["alias"] as string | undefined,
    id: parsed.options["id"] as string | undefined,
    first: parsed.options["first"] as number | undefined,
    last: parsed.options["last"] as number | undefined,
    all: parsed.options["all"] as boolean | undefined,
    range: parsed.options["range"] as string | undefined,
    tools: parsed.options["tools"] as boolean | undefined,
    role: parsed.options["role"] as string | undefined,
    format: parsed.options["format"] as "text" | "json" | undefined,
    output: parsed.options["output"] as string | undefined,
    config,
    getSession,
  });

  process.stdout.write(result.stdout);
  process.stderr.write(result.stderr);
  process.exit(result.exitCode);
}

async function handleSearchCommand(parsed: ParsedArgs): Promise<void> {
  const config = loadConfig();
  const searchSessions = createSearchService(config);

  const result = await runSearchCommand({
    text: parsed.options["text"] as string | undefined,
    config,
    searchSessions,
  });

  process.stdout.write(result.stdout);
  process.stderr.write(result.stderr);
  process.exit(result.exitCode);
}

async function handleListNewCommand(parsed: ParsedArgs): Promise<void> {
  const config = loadConfig();
  const list = createListServiceFromConfig(config);

  const result = await runListCommand({
    agent: parsed.options["agent"] as string | undefined,
    alias: parsed.options["alias"] as string | undefined,
    q: parsed.options["q"] as string | undefined,
    config,
    list,
  });

  process.stdout.write(result.stdout);
  process.stderr.write(result.stderr);
  process.exit(result.exitCode);
}

async function handleDetailCommand(parsed: ParsedArgs): Promise<void> {
  const config = loadConfig();
  const getSession = createDetailService(config);

  // Support positional session spec: `oas detail <session-id>`
  const sessionSpec = parsed.options["session"] as string | undefined || parsed.positional[0];

  const result = await runDetailCommand({
    session: sessionSpec,
    agent: parsed.options["agent"] as string | undefined,
    alias: parsed.options["alias"] as string | undefined,
    id: parsed.options["id"] as string | undefined,
    config,
    getSession,
  });

  process.stdout.write(result.stdout);
  process.stderr.write(result.stderr);
  process.exit(result.exitCode);
}

async function handleCloneCommand(parsed: ParsedArgs): Promise<void> {
  const config = loadConfig();
  const clone = createCloneServiceFromConfig(config);

  const result = await runCloneCommand({
    from: parsed.options["from"] as string | undefined,
    to: parsed.options["to"] as string | undefined,
    config,
    clone,
  });

  process.stdout.write(result.stdout);
  process.stderr.write(result.stderr);
  process.exit(result.exitCode);
}

