// ============================================================================
// Main
// ============================================================================

async function main() {
  const argv = process.argv.slice(2);
  
  if (argv.length === 0 || argv[0] === "--help" || argv[0] === "-h") {
    showHelp();
    return;
  }

  const command = argv[0];
  const restArgs = argv.slice(1);

  // Handle legacy commands
  if (command === "list" || command === "recent") {
    const limitArg = restArgs[0];
    if (limitArg === "--help" || limitArg === "-h") {
      showHelp();
      return;
    }
    const limit = limitArg ? parseInt(limitArg, 10) : 10;
    if (isNaN(limit) || limit <= 0) {
      console.error("Error: limit must be a positive number");
      process.exit(1);
    }
    listRecentSessions(limit);
    return;
  }

  if (command === "find" || command === "show") {
    const sessionId = restArgs[0];
    if (!sessionId || sessionId === "--help" || sessionId === "-h") {
      console.error("Usage: oas find <session-id>");
      process.exit(1);
    }
    findSession(sessionId);
    return;
  }

  // Handle new commands
  if (command === "sessions") {
    const parsed = parseArgs(restArgs);
    if (parsed.options["help"] || parsed.options["h"]) {
      showHelp();
      return;
    }
    await handleSessionsCommand(parsed);
    return;
  }

  if (command === "read") {
    const parsed = parseArgs(restArgs);
    if (parsed.options["help"] || parsed.options["h"]) {
      showHelp();
      return;
    }
    await handleReadCommand(parsed);
    return;
  }

  if (command === "search") {
    const parsed = parseArgs(restArgs);
    if (parsed.options["help"] || parsed.options["h"]) {
      showHelp();
      return;
    }
    await handleSearchCommand(parsed);
    return;
  }

  if (command === "list-new") {
    const parsed = parseArgs(restArgs);
    if (parsed.options["help"] || parsed.options["h"]) {
      showHelp();
      return;
    }
    await handleListNewCommand(parsed);
    return;
  }

  if (command === "detail") {
    const parsed = parseArgs(restArgs);
    if (parsed.options["help"] || parsed.options["h"]) {
      showHelp();
      return;
    }
    await handleDetailCommand(parsed);
    return;
  }

  if (command === "clone") {
    const parsed = parseArgs(restArgs);
    if (parsed.options["help"] || parsed.options["h"]) {
      showHelp();
      return;
    }
    await handleCloneCommand(parsed);
    return;
  }

  if (command === "onboard") {
    // Explanation: This command initializes 'bd' (beads) for the project.
    // It will set up the necessary configuration files for issue tracking.
    const proc = Bun.spawn(["bd", "onboard"], {
      stdout: "inherit",
      stderr: "inherit",
    });
    const exitCode = await proc.exited;
    process.exit(exitCode);
    return;
  }

  // Unknown command
  console.error(`Unknown command: ${command}`);
  console.log("");
  console.log("Usage: oas <command> [options]");
  console.log("");
  console.log("Commands:");
  console.log("  list, recent   List recent sessions");
  console.log("  find, show     Show session details");
  console.log("  sessions       List sessions with time filtering");
  console.log("  list-new       List sessions with agent/alias/query filters");
  console.log("  detail         Show session detail view");
  console.log("  read           Read session messages");
  console.log("  search         Search sessions by title and content");
  console.log("  clone          Clone session between agents");
  console.log("  onboard        Initialize bd (beads) for the project");
  console.log("");
  console.log("Run 'oas --help' for more information.");
  process.exit(1);
}

main().catch((error) => {
  console.error("Error:", error instanceof Error ? error.message : String(error));
  process.exit(1);
});
